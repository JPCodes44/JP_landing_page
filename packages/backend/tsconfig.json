{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["ESNext"],
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["bun-types"],
    "allowJs": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*", "next.config.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
